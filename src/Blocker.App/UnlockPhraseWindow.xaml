<ui:FluentWindow x:Class="Blocker.App.UnlockPhraseWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Potwierdzenie"
                 Width="560"
                 Height="390"
                 MinWidth="420"
                 MinHeight="320"
                 ResizeMode="CanResizeWithGrip"
                 WindowStartupLocation="CenterOwner"
                 Background="{DynamicResource AppChromeBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="Potwierdzenie Focus Lock"
                     Margin="8,8,8,0" />

        <Grid Grid.Row="1"
              Margin="18">
            <ui:CardControl Header="Wpisz fraze potwierdzajaca"
                            BorderBrush="{DynamicResource AppPanelBorderBrush}"
                            Background="{DynamicResource AppPanelBrush}"
                            Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ui:InfoBar Grid.Row="0"
                                IsOpen="True"
                                IsClosable="False"
                                Severity="Warning"
                                Title="Wczesne zakonczenie sesji"
                                Message="Aby zakonczyc blokade przed uplywem 30 minut, wpisz dokladnie wymagana fraze." />

                    <ui:TextBox Grid.Row="1"
                                Margin="0,14,0,0"
                                IsReadOnly="True"
                                Text="NIC_GLUPIEGO_NIE_ZROBIE" />

                    <ui:TextBox x:Name="PhraseTextBox"
                                Grid.Row="2"
                                Margin="0,10,0,0"
                                Height="42"
                                VerticalContentAlignment="Center"
                                FontSize="14"
                                PlaceholderText="Wpisz fraze..." />

                    <WrapPanel Grid.Row="3"
                               Margin="0,18,0,0"
                               HorizontalAlignment="Right">
                        <ui:Button MinWidth="120"
                                   Height="40"
                                   Margin="0,0,12,10"
                                   Appearance="Secondary"
                                   Click="HandleCancelClick"
                                   Content="Anuluj" />
                        <ui:Button MinWidth="190"
                                   Height="40"
                                   Margin="0,0,0,10"
                                   Appearance="Danger"
                                   Click="HandleConfirmClick"
                                   Content="Potwierdz i wylacz" />
                    </WrapPanel>
                </Grid>
            </ui:CardControl>
        </Grid>
    </Grid>
</ui:FluentWindow>
