<Application x:Class="Blocker.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="AppChromeBrush" Color="#0B0F1C" />
            <SolidColorBrush x:Key="AppPanelBrush" Color="#121A2A" />
            <SolidColorBrush x:Key="AppPanelBorderBrush" Color="#243551" />
            <SolidColorBrush x:Key="AppMutingTextBrush" Color="#9FB0CC" />
            <LinearGradientBrush x:Key="AppHeroBrush"
                                 StartPoint="0,0"
                                 EndPoint="1,1">
                <GradientStop Offset="0.0" Color="#0E203B" />
                <GradientStop Offset="0.55" Color="#152846" />
                <GradientStop Offset="1.0" Color="#1C2D4A" />
            </LinearGradientBrush>
        </ResourceDictionary>
    </Application.Resources>
</Application>
