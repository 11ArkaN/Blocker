<ui:FluentWindow x:Class="Blocker.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Blocker"
                 Width="1020"
                 Height="720"
                 MinWidth="640"
                 MinHeight="520"
                 WindowStartupLocation="CenterScreen"
                 Foreground="White"
                 Background="{DynamicResource AppChromeBrush}">
    <Grid TextElement.Foreground="White">
        <Rectangle Fill="#060A10" />

        <!-- Ambient glow: top-left teal -->
        <Ellipse Width="520"
                 Height="520"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-220,-200,0,0"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Offset="0" Color="#200E7490" />
                    <GradientStop Offset="1" Color="#00000000" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Ambient glow: bottom-right indigo -->
        <Ellipse Width="600"
                 Height="600"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-260,-260"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Offset="0" Color="#163730B8" />
                    <GradientStop Offset="1" Color="#00000000" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ui:TitleBar Grid.Row="0"
                         Title="Blocker"
                         Margin="8,8,8,0" />

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
              <StackPanel Margin="24,10,24,24">

                <!-- ═══════════════════════════════════════════ -->
                <!-- HERO BANNER                                -->
                <!-- ═══════════════════════════════════════════ -->
                <Border
                        CornerRadius="14"
                        BorderThickness="1"
                        BorderBrush="#152540"
                        Padding="26,22"
                        Background="{DynamicResource AppHeroBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: Title + Description -->
                        <StackPanel Grid.Column="0"
                                    VerticalAlignment="Center">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#0EA5E9"
                                       Text="{Binding Localization[Main.FocusDashboardHeader]}" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#EDF2FA"
                                       Text="{Binding Localization[Main.HeroTitle]}" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#6B809A"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       MaxWidth="480"
                                       HorizontalAlignment="Left"
                                       Text="{Binding Localization[Main.HeroDescription]}" />
                        </StackPanel>

                        <!-- Right: Badges + Language -->
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="28,0,0,0">
                            <ui:Badge Appearance="{Binding ModeBadgeAppearance}"
                                      Margin="0,0,0,6"
                                      Foreground="#F3F8FF"
                                      Content="{Binding StatusBadgeText}" />
                            <ui:Badge Appearance="{Binding GuardianBadgeAppearance}"
                                      Foreground="#F3F8FF"
                                      Content="{Binding GuardianStatus}" />
                            <TextBlock Margin="0,16,0,4"
                                       Foreground="{DynamicResource AppMutingTextBrush}"
                                       FontSize="11"
                                       Text="{Binding Localization[Main.LanguageLabel]}" />
                            <ComboBox x:Name="LanguageComboBox"
                                      SelectedValue="{Binding SelectedLanguageCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Tag"
                                      SelectionChanged="HandleLanguageSelectionChanged"
                                      MinWidth="150">
                                <ComboBoxItem Tag="pl"
                                              Content="{Binding Localization[Main.LanguagePolish]}" />
                                <ComboBoxItem Tag="en"
                                              Content="{Binding Localization[Main.LanguageEnglish]}" />
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══════════════════════════════════════════ -->
                <!-- STATUS + FOCUS LOCK SECTIONS               -->
                <!-- ═══════════════════════════════════════════ -->
                <StackPanel>

                    <!-- ── Status & Controls ── -->
                    <StackPanel Orientation="Horizontal"
                                Margin="4,20,0,10">
                        <Border Width="3"
                                Height="14"
                                CornerRadius="2"
                                Background="#0EA5E9" />
                        <TextBlock Margin="10,0,0,0"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#4B6178"
                                   Text="{Binding Localization[Main.StatusControlHeader]}" />
                    </StackPanel>

                    <Border CornerRadius="12"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource AppPanelBorderBrush}"
                            Background="{DynamicResource AppPanelBrush}"
                            Padding="20,18">
                        <StackPanel>
                            <ui:InfoBar IsOpen="True"
                                        IsClosable="False"
                                        Foreground="#F3F8FF"
                                        Severity="{Binding StatusSeverity}"
                                        Title="{Binding StatusTitle}"
                                        Message="{Binding StatusText}" />

                            <!-- Status indicator badges -->
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Margin="0,0,8,0">
                                    <TextBlock FontSize="11"
                                               Foreground="{DynamicResource AppMutingTextBrush}"
                                               Text="{Binding Localization[Main.AdminLabel]}" />
                                    <ui:Badge Margin="0,6,0,0"
                                              Foreground="#F3F8FF"
                                              Appearance="{Binding AdminBadgeAppearance}"
                                              Content="{Binding AdminStatus}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Margin="8,0,8,0">
                                    <TextBlock FontSize="11"
                                               Foreground="{DynamicResource AppMutingTextBrush}"
                                               Text="{Binding Localization[Main.GuardianLabel]}" />
                                    <ui:Badge Margin="0,6,0,0"
                                              Foreground="#F3F8FF"
                                              Appearance="{Binding GuardianBadgeAppearance}"
                                              Content="{Binding GuardianStatus}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            Margin="8,0,0,0">
                                    <TextBlock FontSize="11"
                                               Foreground="{DynamicResource AppMutingTextBrush}"
                                               Text="{Binding Localization[Main.ModeLabel]}" />
                                    <ui:Badge Margin="0,6,0,0"
                                              Foreground="#F3F8FF"
                                              Appearance="{Binding ModeBadgeAppearance}"
                                              Content="{Binding StatusBadgeText}" />
                                </StackPanel>
                            </Grid>

                            <!-- Separator -->
                            <Rectangle Height="1"
                                       Fill="#141E2E"
                                       Margin="0,16,0,16" />

                            <!-- Activity info -->
                            <TextBlock Foreground="{DynamicResource AppMutingTextBrush}"
                                       FontSize="12"
                                       Text="{Binding ActiveSinceText}" />
                            <TextBlock Margin="0,5,0,0"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="#C0D0E4"
                                       Text="{Binding FocusLockText}" />

                            <!-- Progress bar -->
                            <ProgressBar Margin="0,12,0,0"
                                         Height="6"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="{Binding FocusProgressPercent, Mode=OneWay}" />

                            <!-- Action buttons -->
                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ui:Button Grid.Column="0"
                                           Height="46"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Center"
                                           Foreground="#FFFFFF"
                                           Appearance="{Binding ToggleButtonAppearance}"
                                           IsEnabled="{Binding CanInteract}"
                                           Command="{Binding ToggleBlockCommand}"
                                           Content="{Binding ToggleButtonText}" />
                                <ui:Button Grid.Column="1"
                                           Margin="10,0,0,0"
                                           Height="46"
                                           MinWidth="140"
                                           HorizontalContentAlignment="Center"
                                           Foreground="#FFFFFF"
                                           Appearance="Secondary"
                                           IsEnabled="{Binding CanInteract}"
                                           Command="{Binding RefreshCommand}"
                                           Content="{Binding Localization[Main.RefreshStatus]}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Focus Lock ── -->
                    <StackPanel Orientation="Horizontal"
                                Margin="4,20,0,10">
                        <Border Width="3"
                                Height="14"
                                CornerRadius="2"
                                Background="#F59E0B" />
                        <TextBlock Margin="10,0,0,0"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#4B6178"
                                   Text="{Binding Localization[Main.FocusLockHeader]}" />
                    </StackPanel>

                    <Border CornerRadius="12"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource AppPanelBorderBrush}"
                            Background="{DynamicResource AppPanelBrush}"
                            Padding="20,18">
                        <StackPanel>
                            <TextBlock Foreground="{DynamicResource AppMutingTextBrush}"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Text="{Binding Localization[Main.FocusLockDescription]}" />
                            <ui:InfoBar Margin="0,12,0,0"
                                        IsClosable="False"
                                        IsOpen="{Binding IsFocusPhraseRequired}"
                                        Foreground="#F3F8FF"
                                        Severity="Warning"
                                        Title="{Binding Localization[Main.FocusPhraseRequiredTitle]}"
                                        Message="{Binding Localization[Main.FocusPhraseRequiredMessage]}" />
                            <Border Margin="0,12,0,0"
                                    Padding="14,10"
                                    CornerRadius="8"
                                    BorderThickness="1"
                                    BorderBrush="#162338"
                                    Background="#090F18">
                                <TextBlock TextWrapping="Wrap"
                                           Text="{Binding UnlockPhraseDisplay}"
                                           FontFamily="Cascadia Mono"
                                           FontSize="13"
                                           Foreground="#8FA4BE" />
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ═══════════════════════════════════════════ -->
                <!-- EVENT LOG                                  -->
                <!-- ═══════════════════════════════════════════ -->
                <StackPanel Orientation="Horizontal"
                            Margin="4,20,0,10">
                    <Border Width="3"
                            Height="14"
                            CornerRadius="2"
                            Background="#64748B" />
                    <TextBlock Margin="10,0,0,0"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#4B6178"
                               Text="{Binding Localization[Main.EventLogHeader]}" />
                </StackPanel>

                <Border CornerRadius="12"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource AppPanelBorderBrush}"
                        Background="{DynamicResource AppPanelBrush}"
                        Padding="14">
                    <ListBox ItemsSource="{Binding ActivityLog}"
                             MinHeight="220"
                             MaxHeight="340"
                             FontFamily="Cascadia Mono"
                             FontSize="12"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,3"
                                        Padding="10,7"
                                        CornerRadius="6"
                                        Background="#0A1018"
                                        BorderBrush="#141E2E"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding}"
                                               Foreground="#A0B4CC"
                                               TextWrapping="Wrap" />
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

              </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</ui:FluentWindow>
