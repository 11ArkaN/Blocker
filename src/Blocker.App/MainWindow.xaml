<ui:FluentWindow x:Class="Blocker.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Blocker"
                 Width="1020"
                 Height="720"
                 MinWidth="640"
                 MinHeight="520"
                 WindowStartupLocation="CenterScreen"
                 Background="{DynamicResource AppChromeBrush}">
    <Grid>
        <Rectangle Fill="#0A1220" />
        <Ellipse Width="380"
                 Height="380"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-120,-140,0,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Offset="0" Color="#3A66A6" />
                    <GradientStop Offset="1" Color="#003A66A6" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="420"
                 Height="420"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-180,-160">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Offset="0" Color="#30406F9A" />
                    <GradientStop Offset="1" Color="#00406F9A" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ui:TitleBar Grid.Row="0"
                         Title="Blocker"
                         Margin="8,8,8,0" />

            <Grid Grid.Row="1"
                  Margin="20,14,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ui:CardControl Grid.Row="0"
                                Header="{Binding Localization[Main.FocusDashboardHeader]}"
                                BorderBrush="#34507B"
                                Background="{DynamicResource AppHeroBrush}"
                                Padding="18">
                    <WrapPanel>
                        <StackPanel MinWidth="320"
                                    Margin="0,0,16,10">
                            <TextBlock FontSize="28"
                                       FontWeight="SemiBold"
                                       Text="{Binding Localization[Main.HeroTitle]}" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#C8D8F3"
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       Text="{Binding Localization[Main.HeroDescription]}" />
                        </StackPanel>
                        <StackPanel VerticalAlignment="Center"
                                    Margin="0,0,0,6">
                            <ui:Badge Appearance="{Binding ModeBadgeAppearance}"
                                      Margin="0,0,0,8"
                                      Content="{Binding StatusBadgeText}" />
                            <ui:Badge Appearance="{Binding GuardianBadgeAppearance}"
                                      Content="{Binding GuardianStatus}" />
                            <TextBlock Margin="0,12,0,4"
                                       Foreground="{DynamicResource AppMutingTextBrush}"
                                       Text="{Binding Localization[Main.LanguageLabel]}" />
                            <ComboBox x:Name="LanguageComboBox"
                                      SelectedValue="{Binding SelectedLanguageCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Tag"
                                      SelectionChanged="HandleLanguageSelectionChanged"
                                      MinWidth="150">
                                <ComboBoxItem Tag="pl"
                                              Content="{Binding Localization[Main.LanguagePolish]}" />
                                <ComboBoxItem Tag="en"
                                              Content="{Binding Localization[Main.LanguageEnglish]}" />
                            </ComboBox>
                        </StackPanel>
                    </WrapPanel>
                </ui:CardControl>

                <StackPanel Grid.Row="1"
                            Margin="0,14,0,14">
                    <ui:CardControl Header="{Binding Localization[Main.StatusControlHeader]}"
                                    BorderBrush="{DynamicResource AppPanelBorderBrush}"
                                    Background="{DynamicResource AppPanelBrush}"
                                    Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ui:InfoBar Grid.Row="0"
                                        IsOpen="True"
                                        IsClosable="False"
                                        Severity="{Binding StatusSeverity}"
                                        Title="{Binding StatusTitle}"
                                        Message="{Binding StatusText}" />

                            <WrapPanel Grid.Row="1"
                                       Margin="0,12,0,0">
                                <StackPanel MinWidth="150"
                                            Margin="0,0,10,10">
                                    <TextBlock Foreground="{DynamicResource AppMutingTextBrush}"
                                               Text="{Binding Localization[Main.AdminLabel]}" />
                                    <ui:Badge Margin="0,6,0,0"
                                              Appearance="{Binding AdminBadgeAppearance}"
                                              Content="{Binding AdminStatus}" />
                                </StackPanel>
                                <StackPanel MinWidth="150"
                                            Margin="0,0,10,10">
                                    <TextBlock Foreground="{DynamicResource AppMutingTextBrush}"
                                               Text="{Binding Localization[Main.GuardianLabel]}" />
                                    <ui:Badge Margin="0,6,0,0"
                                              Appearance="{Binding GuardianBadgeAppearance}"
                                              Content="{Binding GuardianStatus}" />
                                </StackPanel>
                                <StackPanel MinWidth="150"
                                            Margin="0,0,0,10">
                                    <TextBlock Foreground="{DynamicResource AppMutingTextBrush}"
                                               Text="{Binding Localization[Main.ModeLabel]}" />
                                    <ui:Badge Margin="0,6,0,0"
                                              Appearance="{Binding ModeBadgeAppearance}"
                                              Content="{Binding StatusBadgeText}" />
                                </StackPanel>
                            </WrapPanel>

                            <WrapPanel Grid.Row="2"
                                       Margin="0,14,0,0">
                                <StackPanel MinWidth="260"
                                            Margin="0,0,14,12">
                                    <TextBlock Foreground="{DynamicResource AppMutingTextBrush}"
                                               Text="{Binding ActiveSinceText}" />
                                    <TextBlock Margin="0,8,0,0"
                                               FontWeight="SemiBold"
                                               Text="{Binding FocusLockText}" />
                                    <ProgressBar Margin="0,10,0,0"
                                                 MinWidth="220"
                                                 Height="8"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding FocusProgressPercent, Mode=OneWay}" />
                                </StackPanel>

                                <StackPanel MinWidth="200"
                                            VerticalAlignment="Top">
                                    <ui:Button Height="52"
                                               FontSize="17"
                                               FontWeight="SemiBold"
                                               Appearance="{Binding ToggleButtonAppearance}"
                                               IsEnabled="{Binding CanInteract}"
                                               Command="{Binding ToggleBlockCommand}"
                                               Content="{Binding ToggleButtonText}" />
                                    <ui:Button Margin="0,10,0,0"
                                               Appearance="Secondary"
                                               IsEnabled="{Binding CanInteract}"
                                               Command="{Binding RefreshCommand}"
                                               Content="{Binding Localization[Main.RefreshStatus]}" />
                                </StackPanel>
                            </WrapPanel>
                        </Grid>
                    </ui:CardControl>

                    <ui:CardControl Margin="0,12,0,0"
                                    Header="{Binding Localization[Main.FocusLockHeader]}"
                                    BorderBrush="{DynamicResource AppPanelBorderBrush}"
                                    Background="{DynamicResource AppPanelBrush}"
                                    Padding="14">
                        <StackPanel>
                            <TextBlock Foreground="{DynamicResource AppMutingTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding Localization[Main.FocusLockDescription]}" />
                            <ui:InfoBar Margin="0,12,0,0"
                                        IsClosable="False"
                                        IsOpen="{Binding IsFocusPhraseRequired}"
                                        Severity="Warning"
                                        Title="{Binding Localization[Main.FocusPhraseRequiredTitle]}"
                                        Message="{Binding Localization[Main.FocusPhraseRequiredMessage]}" />
                            <Border Margin="0,12,0,0"
                                    Padding="12"
                                    CornerRadius="10"
                                    BorderThickness="1"
                                    BorderBrush="#2E456B"
                                    Background="#0F1A2B">
                                <TextBlock TextWrapping="Wrap"
                                           Text="{Binding UnlockPhraseDisplay}"
                                           FontFamily="Cascadia Mono"
                                           Foreground="#C7D8F0" />
                            </Border>
                        </StackPanel>
                    </ui:CardControl>
                </StackPanel>

                <ui:CardControl Grid.Row="2"
                                Header="{Binding Localization[Main.EventLogHeader]}"
                                BorderBrush="{DynamicResource AppPanelBorderBrush}"
                                Background="{DynamicResource AppPanelBrush}"
                                Padding="12">
                    <ListBox ItemsSource="{Binding ActivityLog}"
                             MinHeight="120"
                             FontFamily="Cascadia Mono"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="10,8"
                                        CornerRadius="8"
                                        Background="#11213A"
                                        BorderBrush="#2B4366"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding}"
                                               Foreground="#E6EEFF"
                                               TextWrapping="Wrap" />
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ui:CardControl>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
