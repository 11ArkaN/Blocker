<ui:FluentWindow x:Class="Blocker.App.UnlockPhraseWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Confirmation"
                 Width="620"
                 Height="440"
                 MinWidth="340"
                 MinHeight="320"
                 ResizeMode="CanResizeWithGrip"
                 WindowStartupLocation="CenterOwner"
                 Foreground="White"
                 Background="{DynamicResource AppChromeBrush}">
    <Grid TextElement.Foreground="White">
        <Rectangle Fill="#060A10" />

        <!-- Ambient glow: top-left -->
        <Ellipse Width="280"
                 Height="280"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-120,-130,0,0"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Offset="0" Color="#200E7490" />
                    <GradientStop Offset="1" Color="#00000000" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Ambient glow: bottom-right -->
        <Ellipse Width="320"
                 Height="320"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-150,-130"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Offset="0" Color="#163730B8" />
                    <GradientStop Offset="1" Color="#00000000" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ui:TitleBar Grid.Row="0"
                         x:Name="DialogTitleBar"
                         Title="Focus Lock confirmation"
                         Margin="8,8,8,0" />

            <Border Grid.Row="1"
                    x:Name="DialogCard"
                    Margin="20,14,20,20"
                    CornerRadius="14"
                    BorderThickness="1"
                    BorderBrush="#152540"
                    Padding="26,22"
                    Background="{DynamicResource AppHeroBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Focusable="False">
                    <Grid x:Name="DialogContentGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   x:Name="DialogSectionTitleTextBlock"
                                   TextWrapping="Wrap"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#EDF2FA"
                                   Text="Enter confirmation phrase" />

                        <Border Grid.Row="1"
                                x:Name="DialogMessageContainer"
                                Margin="0,14,0,0"
                                CornerRadius="10"
                                Padding="14,12"
                                BorderThickness="1"
                                BorderBrush="#85651C"
                                Background="#3D3518">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="DialogMessageTitleTextBlock"
                                           Grid.Row="0"
                                           TextWrapping="Wrap"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Foreground="#FFF0CC" 
                                           Text="Early session end" />
                                <TextBlock x:Name="DialogMessageTextBlock"
                                           Grid.Row="1"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           FontSize="13"
                                           Foreground="#D4C49A"
                                           Text="To disable blocking before 30 minutes, enter the required phrase exactly." />
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                x:Name="ReferencePhraseContainer"
                                Margin="0,14,0,0"
                                Padding="14,10"
                                CornerRadius="8"
                                BorderBrush="#162338"
                                BorderThickness="1"
                                Background="#090F18">
                            <TextBlock x:Name="ReferencePhraseTextBlock"
                                       Text="SAMPLE_UNLOCK_PHRASE"
                                       TextWrapping="Wrap"
                                       FontFamily="Cascadia Mono"
                                       FontSize="13"
                                       Foreground="#8FA4BE" />
                        </Border>

                        <ui:TextBox x:Name="PhraseTextBox"
                                    Grid.Row="3"
                                    Margin="0,12,0,0"
                                    MinHeight="42"
                                    VerticalContentAlignment="Center"
                                    FontSize="14"
                                    PlaceholderText="Enter phrase..." />

                        <Grid Grid.Row="4"
                              Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ui:Button Grid.Column="0"
                                       x:Name="CancelButton"
                                       MinWidth="108"
                                       MinHeight="40"
                                       HorizontalContentAlignment="Center"
                                       Appearance="Secondary"
                                       Click="HandleCancelClick"
                                       Content="Cancel" />
                            <ui:Button Grid.Column="2"
                                       x:Name="ConfirmButton"
                                       MinWidth="146"
                                       MinHeight="40"
                                       HorizontalContentAlignment="Center"
                                       Appearance="Danger"
                                       Click="HandleConfirmClick"
                                       Content="Confirm and disable" />
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
