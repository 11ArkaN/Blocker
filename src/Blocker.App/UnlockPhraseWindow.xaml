<ui:FluentWindow x:Class="Blocker.App.UnlockPhraseWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Potwierdzenie"
                 Width="560"
                 Height="420"
                 MinWidth="360"
                 MinHeight="300"
                 ResizeMode="CanResizeWithGrip"
                 WindowStartupLocation="CenterOwner"
                 Background="{DynamicResource AppChromeBrush}">
    <Grid>
        <Rectangle Fill="#0A1220" />
        <Ellipse Width="260"
                 Height="260"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-110,-130,0,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Offset="0" Color="#3A66A6" />
                    <GradientStop Offset="1" Color="#003A66A6" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="300"
                 Height="300"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-140,-120">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Offset="0" Color="#30406F9A" />
                    <GradientStop Offset="1" Color="#00406F9A" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ui:TitleBar Grid.Row="0"
                         x:Name="DialogTitleBar"
                         Title="Potwierdzenie Focus Lock"
                         Margin="8,8,8,0" />

            <ScrollViewer Grid.Row="1"
                          Margin="20,14,20,20"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          CanContentScroll="False">
                <ui:CardControl x:Name="DialogCard"
                                Header="Wpisz fraze potwierdzajaca"
                                BorderBrush="#34507B"
                                Background="{DynamicResource AppHeroBrush}"
                                Padding="18">
                    <Grid MinWidth="280">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ui:InfoBar Grid.Row="0"
                                    x:Name="DialogInfoBar"
                                    IsOpen="True"
                                    IsClosable="False"
                                    Severity="Warning"
                                    Title="Wczesne zakonczenie sesji"
                                    Message="Aby zakonczyc blokade przed uplywem 30 minut, wpisz dokladnie wymagana fraze." />

                        <Border Grid.Row="1"
                                x:Name="ReferencePhraseContainer"
                                Margin="0,14,0,0"
                                Padding="10,8"
                                CornerRadius="8"
                                BorderBrush="#2E456B"
                                BorderThickness="1"
                                Background="#0F1A2B">
                            <TextBlock x:Name="ReferencePhraseTextBlock"
                                       Text="NIC_GLUPIEGO_NIE_ZROBIE"
                                       TextWrapping="Wrap"
                                       FontFamily="Cascadia Mono"
                                       Foreground="#C7D8F0" />
                        </Border>

                        <ui:TextBox x:Name="PhraseTextBox"
                                    Grid.Row="2"
                                    Margin="0,10,0,0"
                                    MinHeight="42"
                                    VerticalContentAlignment="Center"
                                    FontSize="14"
                                    PlaceholderText="Wpisz fraze..." />

                        <WrapPanel Grid.Row="3"
                                   Margin="0,18,0,0"
                                   HorizontalAlignment="Right">
                            <ui:Button MinWidth="120"
                                       Height="40"
                                       Margin="0,0,12,10"
                                       Appearance="Secondary"
                                       Click="HandleCancelClick"
                                       Content="Anuluj" />
                            <ui:Button MinWidth="190"
                                       x:Name="ConfirmButton"
                                       Height="40"
                                       Margin="0,0,0,10"
                                       Appearance="Danger"
                                       Click="HandleConfirmClick"
                                       Content="Potwierdz i wylacz" />
                        </WrapPanel>
                    </Grid>
                </ui:CardControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</ui:FluentWindow>
