<Window x:Class="Blocker.App.UnlockPhraseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Unlock Required"
        Width="520"
        Height="240"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#101826"
        Foreground="#E6EBF5">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   TextWrapping="Wrap"
                   FontSize="14"
                   Text="Focus lock is active. To disable blocking, type exactly: NIC_GLUPIEGO_NIE_ZROBIE" />

        <TextBox x:Name="PhraseTextBox"
                 Grid.Row="1"
                 Margin="0,14,0,0"
                 Height="34"
                 VerticalContentAlignment="Center"
                 FontSize="14" />

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Width="110"
                    Height="34"
                    Margin="0,0,8,0"
                    Click="HandleCancelClick"
                    Content="Cancel" />
            <Button Width="150"
                    Height="34"
                    IsDefault="True"
                    Click="HandleConfirmClick"
                    Content="Confirm disable" />
        </StackPanel>
    </Grid>
</Window>
