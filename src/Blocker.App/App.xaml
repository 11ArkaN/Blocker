<Application x:Class="Blocker.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="AppChromeBrush" Color="#070B12" />
            <SolidColorBrush x:Key="AppPanelBrush" Color="#0D1219" />
            <SolidColorBrush x:Key="AppPanelBorderBrush" Color="#182334" />
            <SolidColorBrush x:Key="AppMutingTextBrush" Color="#5F7289" />
            <SolidColorBrush x:Key="AppAccentBrush" Color="#0EA5E9" />
            <LinearGradientBrush x:Key="AppHeroBrush"
                                 StartPoint="0,0"
                                 EndPoint="1,1">
                <GradientStop Offset="0.0" Color="#0B1628" />
                <GradientStop Offset="0.5" Color="#101E36" />
                <GradientStop Offset="1.0" Color="#0C1A30" />
            </LinearGradientBrush>
        </ResourceDictionary>
    </Application.Resources>
</Application>
